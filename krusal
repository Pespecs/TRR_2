#include <bits/stdc++.h>
using namespace std;

int n;
using iii = pair<int, pair<int, int>>;
ifstream f1("CK.INP");
ofstream f2("CK.OUT");
int c[101][101];
priority_queue<iii, vector<iii>, greater<iii>> pq;
int par[101];

int ufind(int u) {
    if(u == par[u]) return u;
    par[u] = ufind(par[u]);
    return par[u];
}

bool Union(int u, int v) {
    int a = ufind(u);
    int b = ufind(v);
    if(a == b) return true;
    par[b] = a;
    return false;
}

int main() {
    int m;
    f1 >> n >> m;
    vector<iii> ans;
    for(int i = 1; i <= n; i++) {
        par[i] = i;
    }
    for(int i = 0; i < m; i++) {
        int u, v, w;
        f1 >> u >> v >> w;
        pq.push({w, {u, v}});
    }
    int dH = 0;
    while(!pq.empty()) {
        auto u = pq.top(); pq.pop();
        if(!Union(u.second.first, u.second.second)) {
            ans.push_back({u.first, {u.second.first, u.second.second}});
            dH += u.first;
        }
        if(ans.size() == n - 1) break;

    }
    if(ans.size() < n - 1) {
        f2 << 0 << endl;
    } else {
        f2 << dH << endl;
        for(auto x : ans) {
            f2 << x.second.first << " " << x.second.second << " " << x.first << endl;
        }
    }
    return 0;
}
