#include<bits/stdc++.h>
using namespace std;

int n;
ifstream f1("TK.INP");
ofstream f2("TK.OUT");
vector<int> adj[101];
int a[101][101];
int visited[101];
vector<pair<int, int>> ans;

void bfs(int u) {
    queue<int> q;
    q.push(u);
    visited[u] = true;
    while(!q.empty()) {
        int v = q.front(); q.pop();
        for(int i = 1; i <= n; i++) {
            if(a[v][i] && !visited[i]) {
                q.push(i);
                visited[i] = true;
            }
        }
    }
}

int tplt() {
    int lt = 0;
    memset(visited, false, sizeof(visited));
    for(int i = 1; i <= n; i++) {
        if(!visited[i]) {
            lt++;
            bfs(i);
        }
    }
    return lt;
}



int main() {
    f1 >> n;
    for(int i = 1; i <= n; i++) {
        for(int j = 1; j <= n; j++) {
            f1 >> a[i][j];
            //if(a[i][j]) adj[i].push_back(j);
        }
    }
    int lt = tplt();
    int cnt = 0;
    for(int i = 1; i <= n; i++) {
        for(int j = i + 1; j <= n; j++) {
            if(a[i][j]) {
                a[i][j] = a[j][i] = 0;
                if(tplt() > lt) {
                    cnt++;
                    ans.push_back({i, j});
                }
                a[i][j] = a[j][i] = 1;
            }
        }
    }
    f2 << cnt << endl;
    if(cnt > 0) {
        for(auto i : ans) {
            f2 << i.first << " " << i.second << endl;
        }
    }
    return 0;
}
